<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>D2P CONSOLE – DIGITAL TO PHYSICAL</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            background: radial-gradient(circle at 20% 30%, #0a0f1e, #03060c);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Courier New', 'Fira Code', 'Monaco', monospace;
            padding: 20px;
        }

        /* Main console panel */
        .console {
            max-width: 1400px;
            width: 100%;
            background: rgba(10, 20, 30, 0.75);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 255, 255, 0.4);
            border-radius: 32px;
            padding: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(0,255,255,0.2);
            transition: all 0.2s;
        }

        /* Header with status */
        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            border-bottom: 1px solid #2a6f8f;
            padding-bottom: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .title {
            font-size: 1.8rem;
            font-weight: bold;
            letter-spacing: 4px;
            background: linear-gradient(135deg, #0ff, #3af);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 8px rgba(0,255,255,0.3);
        }

        .badge {
            font-size: 0.8rem;
            background: #000000aa;
            padding: 6px 14px;
            border-radius: 40px;
            border-left: 3px solid #0ff;
            color: #0ff;
            font-weight: bold;
        }

        /* Two-column layout */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        /* Card style */
        .card {
            background: #07121cd9;
            border-radius: 24px;
            padding: 20px;
            border: 1px solid #1e88a0;
            box-shadow: 0 8px 18px rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
        }

        .card h3 {
            color: #0ff;
            font-size: 1.2rem;
            margin-bottom: 16px;
            border-left: 4px solid #0ff;
            padding-left: 12px;
        }

        /* Hologram canvas */
        .hologram-container {
            background: #00000099;
            border-radius: 20px;
            padding: 10px;
            text-align: center;
        }

        canvas {
            width: 100%;
            background: #010a12;
            border-radius: 16px;
            box-shadow: 0 0 0 1px #0ff3, 0 0 0 3px #000;
            cursor: pointer;
        }

        /* Sliders and controls */
        .control-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            color: #8dd0ff;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 6px;
        }

        input, select, button {
            width: 100%;
            background: #0a1422;
            border: 1px solid #2c6275;
            padding: 10px 14px;
            border-radius: 14px;
            color: #0ff;
            font-family: monospace;
            font-weight: bold;
            transition: 0.15s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #0ff;
            box-shadow: 0 0 8px #0ff6;
        }

        button {
            background: linear-gradient(95deg, #0a2a3a, #021018);
            font-weight: bold;
            margin-top: 8px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        button:active {
            transform: scale(0.97);
            background: #0cf2;
        }

        .emergency {
            background: #3a1010;
            border-color: #f44;
            color: #f88;
        }

        .log-area {
            background: #030b10;
            border-radius: 20px;
            padding: 16px;
            font-size: 0.75rem;
            height: 140px;
            overflow-y: auto;
            font-family: monospace;
            color: #8ae2ff;
            border: 1px solid #1f6e7a;
        }

        .log-line {
            border-left: 2px solid #0ff;
            padding-left: 10px;
            margin: 6px 0;
            font-size: 0.7rem;
        }

        @keyframes pulse {
            0% { opacity: 0.6; text-shadow: 0 0 0px #0ff; }
            100% { opacity: 1; text-shadow: 0 0 6px #0ff; }
        }

        .active-pulse {
            animation: pulse 1s infinite;
        }

        @media (max-width: 800px) {
            .grid-2 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="console">
    <div class="status-bar">
        <div class="title">⚡ D2P TRANSMUTER v1.0</div>
        <div class="badge" id="sysStatus">🔴 SYSTEM STANDBY</div>
    </div>

    <div class="grid-2">
        <!-- LEFT PANEL: HOLOGRAM VISUALIZATION + TOUCH -->
        <div class="card">
            <h3>🌀 TOUCHABLE HOLOGRAM FEED</h3>
            <div class="hologram-container">
                <canvas id="hologramCanvas" width="600" height="400" style="width:100%; height:auto; max-width:600px; aspect-ratio:600/400"></canvas>
                <div style="display: flex; gap: 12px; margin-top: 12px;">
                    <button id="rotateBtn">⟳ ROTATE VIEW</button>
                    <button id="hapticTestBtn">✋ SEND HAPTIC PULSE</button>
                </div>
                <p style="font-size: 11px; margin-top: 8px; color: #6aa;">↓ move mouse over hologram → simulated touch feedback</p>
            </div>

            <div class="control-group" style="margin-top: 18px;">
                <label>📡 RF HAPTIC INTENSITY</label>
                <input type="range" id="hapticStrength" min="0" max="100" value="45">
                <div style="display: flex; justify-content: space-between;">
                    <span>soft</span><span id="hapticVal">45%</span><span>solid</span>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL: MATTER PRINTING CONTROLS -->
        <div class="card">
            <h3>🏭 ATOMIC DEPOSITION (REAL OBJECT)</h3>
            <div class="control-group">
                <label>📁 DIGITAL MODEL (STL / OBJ / TENSOR)</label>
                <select id="modelSelect">
                    <option value="bolt">🔩 STEEL BOLT (M6 x 20mm)</option>
                    <option value="gear">⚙️ BRASS GEAR (40 teeth)</option>
                    <option value="emitter">🌀 HOLOGRAM EMITTER PANEL</option>
                    <option value="custom">✨ CUSTOM: 10mm CUBE</option>
                </select>
            </div>

            <div class="control-group">
                <label>🏷️ MATERIAL ALLOY</label>
                <select id="materialSelect">
                    <option value="copper">COPPER (98% dense)</option>
                    <option value="steel">STEEL (Fe + C)</option>
                    <option value="brass">BRASS (Cu/Zn)</option>
                    <option value="carbon">CARBON COMPOSITE</option>
                </select>
            </div>

            <div class="control-group">
                <label>⚡ POWER & PRECISION</label>
                <input type="range" id="powerKw" min="0.8" max="3.5" step="0.1" value="2.2">
                <div>⚡ <span id="powerVal">2.2</span> kW — voxel size <span id="voxelSize">0.12</span> mm</div>
            </div>

            <button id="buildBtn">▶ START PRINTING OBJECT</button>
            <button id="cancelBuild" class="emergency" style="margin-top: 6px;">⛔ EMERGENCY STOP</button>
            <div class="control-group" style="margin-top: 14px;">
                <label>📟 CHAMBER STATUS</label>
                <progress id="buildProgress" value="0" max="100" style="width:100%; height:12px; border-radius:20px;"></progress>
            </div>
        </div>
    </div>

    <!-- BOTTOM: LIVE LOG + WIRELESS SIGNAL MONITOR -->
    <div class="card" style="margin-top: 8px;">
        <h3>📡 DIGITAL-TO-PHYSICAL EVENT LOG</h3>
        <div class="log-area" id="logPanel">
            <div class="log-line">[READY] D2P core online — 2.45GHz / 17.3GHz / 24GHz arrays calibrated</div>
            <div class="log-line">[OK] Holographic emitter detected (copper, 200M nanoantennas)</div>
            <div class="log-line">[WAIT] Awaiting model selection or touch interaction...</div>
        </div>
    </div>
</div>

<script>
    (function(){
        // ---------- DOM elements ----------
        const canvas = document.getElementById('hologramCanvas');
        const ctx = canvas.getContext('2d');
        const sysSpan = document.getElementById('sysStatus');
        const logPanel = document.getElementById('logPanel');
        const hapticSlider = document.getElementById('hapticStrength');
        const hapticValSpan = document.getElementById('hapticVal');
        const powerSlider = document.getElementById('powerKw');
        const powerValSpan = document.getElementById('powerVal');
        const voxelSpan = document.getElementById('voxelSize');
        const buildBtn = document.getElementById('buildBtn');
        const cancelBtn = document.getElementById('cancelBuild');
        const modelSelect = document.getElementById('modelSelect');
        const materialSelect = document.getElementById('materialSelect');
        const progressBar = document.getElementById('buildProgress');
        const rotateBtn = document.getElementById('rotateBtn');
        const hapticTestBtn = document.getElementById('hapticTestBtn');

        // hologram state
        let rotationAngle = 0;
        let mouseX = 0, mouseY = 0;
        let isMouseOverCanvas = false;
        let animationId = null;

        // simulated build state
        let buildingInterval = null;
        let currentBuildProgress = 0;

        // helper: add log
        function addLog(msg, isError = false) {
            const logDiv = document.createElement('div');
            logDiv.className = 'log-line';
            logDiv.style.color = isError ? '#ff8888' : '#8ae2ff';
            logDiv.innerHTML = `[${new Date().toLocaleTimeString()}] ${msg}`;
            logPanel.appendChild(logDiv);
            logDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            // keep last 40 logs
            while(logPanel.children.length > 45) logPanel.removeChild(logPanel.firstChild);
        }

        // update system status indicator
        function setStatus(online, msg) {
            if(online) {
                sysSpan.innerHTML = `🟢 ${msg}`;
                sysSpan.style.color = "#0f0";
            } else {
                sysSpan.innerHTML = `🔴 ${msg}`;
                sysSpan.style.color = "#f66";
            }
        }

        // haptic slider sync
        hapticSlider.addEventListener('input', (e) => {
            let val = e.target.value;
            hapticValSpan.innerText = val + '%';
            addLog(`✋ Haptic RF intensity set to ${val}% (24GHz modulation)`);
        });

        powerSlider.addEventListener('input', (e) => {
            let kw = parseFloat(e.target.value);
            powerValSpan.innerText = kw;
            let vox = (0.08 + (3.5 - kw) * 0.03).toFixed(2);
            voxelSpan.innerText = vox;
            addLog(`⚡ Magnetron power set to ${kw} kW — voxel precision ${vox} mm`);
        });

        // draw interactive 3D hologram (fake volumetric but realistic)
        function drawHologram() {
            if (!ctx) return;
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            canvas.width = w;
            canvas.height = h;

            ctx.clearRect(0, 0, w, h);
            // deep tech grid background
            ctx.fillStyle = "#010a12";
            ctx.fillRect(0, 0, w, h);
            ctx.strokeStyle = "#0ff2";
            ctx.lineWidth = 0.6;
            for(let i = 0; i < w; i+=30){
                ctx.beginPath();
                ctx.moveTo(i, 0);
                ctx.lineTo(i, h);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(0, i%h);
                ctx.lineTo(w, i%h);
                ctx.stroke();
            }

            // floating volumetric object: torus knot / rotating ring
            const centerX = w/2;
            const centerY = h/2 - 20;
            const time = Date.now() * 0.003;
            const radius = Math.min(w,h)*0.28;

            // particle system representing hologram points
            const particleCount = 380;
            for (let i = 0; i < particleCount; i++) {
                const angle = (i / particleCount) * Math.PI * 2 + rotationAngle;
                const radiusVar = radius + Math.sin(angle * 3 + time) * 12;
                const x = centerX + Math.cos(angle + time*0.7) * radiusVar;
                const y = centerY + Math.sin(angle * 2 + time) * radiusVar * 0.6;
                const size = 2 + Math.sin(angle*5 + time)*1.2;

                // mouse proximity -> haptic glow effect
                let dx = mouseX - x;
                let dy = mouseY - y;
                let dist = Math.hypot(dx, dy);
                let intensity = 1.0;
                let glowSize = size;
                if(isMouseOverCanvas && dist < 28) {
                    intensity = 1.6;
                    glowSize = size+3;
                    addLog(`✋ Haptic field disturbed at (${Math.round(x)},${Math.round(y)}) – tactile feedback active`);
                }
                const hue = (angle * 180 + time*90) % 360;
                ctx.beginPath();
                ctx.arc(x, y, glowSize, 0, Math.PI*2);
                ctx.fillStyle = `hsla(${hue}, 100%, 60%, ${0.7*intensity})`;
                ctx.fill();
                ctx.shadowBlur = 10*intensity;
                ctx.shadowColor = "#0ff";
            }
            ctx.shadowBlur = 0;
            // center glowing core
            ctx.beginPath();
            ctx.arc(centerX, centerY, 18, 0, Math.PI*2);
            ctx.fillStyle = "#0ffa";
            ctx.shadowBlur = 18;
            ctx.fill();
            ctx.shadowBlur = 0;
        }

        // animate hologram
        function animateHologram() {
            drawHologram();
            requestAnimationFrame(animateHologram);
        }

        // mouse tracking for touch simulation
        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            mouseX = (e.clientX - rect.left) * scaleX;
            mouseY = (e.clientY - rect.top) * scaleY;
            isMouseOverCanvas = true;
        });
        canvas.addEventListener('mouseleave', () => {
            isMouseOverCanvas = false;
        });

        rotateBtn.addEventListener('click', () => {
            rotationAngle += Math.PI/6;
            addLog(`⟳ Hologram viewpoint rotated – optical phase array updated`);
        });

        hapticTestBtn.addEventListener('click', () => {
            let intensity = parseInt(hapticSlider.value);
            addLog(`✋ MANUAL HAPTIC TRIGGER – ${intensity}% RF force emitted at center (24GHz)`);
            // visual feedback flash
            const flash = document.createElement('div');
            flash.style.position='fixed'; flash.style.top='20%'; flash.style.left='30%'; flash.style.width='40%'; flash.style.height='30%'; flash.style.background='radial-gradient(circle, #0ff2, transparent)'; flash.style.pointerEvents='none'; flash.style.zIndex='9999';
            document.body.appendChild(flash);
            setTimeout(()=>flash.remove(),200);
        });

        // BUILD real object simulation
        function startBuild() {
            if(buildingInterval) {
                addLog("Build already in progress. Cancel or wait.", true);
                return;
            }
            const model = modelSelect.value;
            const material = materialSelect.value;
            const power = parseFloat(powerSlider.value);
            const modelName = modelSelect.options[modelSelect.selectedIndex].text;
            const matName = materialSelect.options[materialSelect.selectedIndex].text;
            addLog(`🔨 STARTING PRINT: ${modelName} (${matName}) | ${power} kW power`);
            setStatus(true, "PRINTING OBJECT...");
            currentBuildProgress = 0;
            progressBar.value = 0;
            // simulate voxel deposition steps
            buildingInterval = setInterval(() => {
                currentBuildProgress += Math.floor(Math.random() * 7) + 2;
                if(currentBuildProgress >= 100) {
                    clearInterval(buildingInterval);
                    buildingInterval = null;
                    progressBar.value = 100;
                    addLog(`✅ OBJECT COMPLETE: ${modelName} printed with ${matName}. Ready in chamber. You can touch it.`);
                    setStatus(true, "READY - object finished");
                    // additional haptic sound-like log
                    addLog(`📦 Density: 92% of bulk. Surface temp 42°C. RF deposition finished.`);
                } else {
                    progressBar.value = currentBuildProgress;
                    if(currentBuildProgress % 23 === 0) 
                        addLog(`🧪 Layer deposition: ${currentBuildProgress}% – electromagnetic interference stable`);
                }
            }, 180);
        }

        function cancelBuild() {
            if(buildingInterval) {
                clearInterval(buildingInterval);
                buildingInterval = null;
                addLog(`⛔ EMERGENCY STOP – RF magnetrons powered down, chamber venting`, true);
                setStatus(false, "EMERGENCY HALT");
                progressBar.value = 0;
            } else {
                addLog(`No active printing to cancel.`, true);
            }
        }

        buildBtn.addEventListener('click', startBuild);
        cancelBtn.addEventListener('click', cancelBuild);

        // initial status
        setStatus(true, "STANDBY - chamber 0.5atm Ar");
        addLog("[SYSTEM] Quantum interference compensation active.");
        addLog("[LINK] Wireless 2.45 / 17.3 GHz sync OK");
        addLog("[HOLO] Emitter ready – hover over canvas for touch feel");

        // start hologram loop
        animateHologram();

        // power default display
        powerValSpan.innerText = powerSlider.value;
        voxelSpan.innerText = (0.08 + (3.5 - parseFloat(powerSlider.value)) * 0.03).toFixed(2);
        hapticValSpan.innerText = hapticSlider.value+"%";
    })();
</script>
</body>
</html>
